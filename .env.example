# Frontend environment variables
# Optional: if set, frontend requests this backend directly instead of same-origin relative paths.
VITE_API_BASE_URL=

# Optional: Vite dev proxy target used in vite.config.ts
BACKEND_URL=http://127.0.0.1:8000

# Backend AQI provider (OpenAQ)
OPENAQ_API_KEY=
OPENAQ_BASE_URL=https://api.openaq.org/v2/latest
OPENAQ_V3_BASE_URL=https://api.openaq.org/v3/latest
